# Server-only - migrations/scripts / server SDK (never bundled for browser)
APPWRITE_API_KEY=""

# Site-wide lockout switch - server-only; never prefix with VITE_
# Set SITE_LOCKED="true" + restart the container to take the whole site down
# behind a takeover screen for everyone. No in-app way to toggle it.
SITE_LOCKED="false"
SITE_LOCK_MESSAGE=""

# PowersText (Bulk SMS OTP for login, signup + password reset) - server-only; never prefix with VITE_
POWERSTEXT_AUTH_KEY=""
POWERSTEXT_SENDER_ID=""
POWERSTEXT_ROUTE="1"
POWERSTEXT_TEMPLATE_ID=""
POWERSTEXT_BASE_URL="http://bulk.powerstext.in/http-tokenkeyapi.php"
POWERSTEXT_MESSAGE_TEMPLATE="Dear Customer Your Login otp is {OTP} DE"

# Client (Vite) - browser bundle. Node scripts also accept these when APPWRITE_* is unset.
VITE_APPWRITE_ENDPOINT="https://coolpool.in/v1"
VITE_APPWRITE_PROJECT_ID="69f23e9d003845289bcc"
VITE_APPWRITE_DATABASE_ID="69f2e5f6000a532410c0"
VITE_APPWRITE_COLLECTION_TRIPS="coolpool_trips"
VITE_APPWRITE_COLLECTION_TRIP_STOPS="coolpool_trip_stops"
VITE_APPWRITE_COLLECTION_BOOKINGS="coolpool_bookings"
VITE_APPWRITE_COLLECTION_USER_ROLES="coolpool_user_roles"
VITE_APPWRITE_COLLECTION_PRICING_RULES="coolpool_pricing_rules"
VITE_APPWRITE_COLLECTION_PROFILES="coolpool_profiles"
VITE_APPWRITE_COLLECTION_DRIVERS="coolpool_drivers"
VITE_APPWRITE_COLLECTION_VEHICLES="coolpool_vehicles"
VITE_APPWRITE_COLLECTION_TRIP_SEAT_RESERVATIONS="coolpool_trip_seat_reservations"
VITE_APPWRITE_DRIVER_DOCS_BUCKET_ID="69f312e500186db2d785"
VITE_GOOGLE_MAPS_API_KEY=""
VITE_APPWRITE_COLLECTION_HERO_BANNERS="coolpool_hero_banners"
VITE_APPWRITE_BANNERS_BUCKET_ID="coolpool_banners_bucket"
# Optional: enables public "Track Ride" safety share links (/track/:token)
VITE_APPWRITE_COLLECTION_TRIP_SHARES="coolpool_trip_shares"
VITE_APPWRITE_COLLECTION_OTP_CODES="coolpool_otp_codes"
VITE_APPWRITE_COLLECTION_COUNTERS="coolpool_counters"
